{
    "name": "skyrich-client",
    "version": "0.1.0",
    "description": "Skyrich Solutions Desktop Application",
    "author": "Skyrich Solutions Team",
    "main": "public/electron.js",
    "private": true,
    "dependencies": {
        "@testing-library/jest-dom": "^5.17.0",
        "@testing-library/react": "^13.4.0",
        "@testing-library/user-event": "^13.5.0",
        "axios": "^1.7.8",
        "chart.js": "^4.4.7",
        "framer-motion": "^12.2.0",
        "lucide-react": "^0.474.0",
        "papaparse": "^5.4.1",
        "react": "^18.3.1",
        "react-chartjs-2": "^5.3.0",
        "react-dom": "^18.3.1",
        "react-router": "^7.1.5",
        "react-scripts": "5.0.1",
        "socket.io-client": "^4.8.1",
        "web-vitals": "^2.1.4"
    },
    "devDependencies": {
        "electron": "^34.2.0",
        "electron-builder": "^25.1.8",
        "tailwindcss": "^3.4.15"
    },
    "scripts": {
        "react-start": "react-scripts start",
        "react-build": "react-scripts build",
        "electron-start": "electron .",
        "electron-build": "electron-builder",
        "test": "react-scripts test",
        "eject": "react-scripts eject"
    },
    "build": {
        "appId": "com.skyrich.app",
        "productName": "SkyrichSolutions",
        "files": [
            "build/**/*",
            "public/electron.js",
            "node_modules/**/*",
            "../Backend/**/*",
            "../Server/**/*"
        ],
        "extraResources": [
            {
                "from": "../Backend/",
                "to": "backend"
            },
            {
                "from": "../Server/",
                "to": "server"
            }
        ],
        "win": {
            "target": "nsis"
        }
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
